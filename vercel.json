{
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "devCommand": "cd web && npm run dev",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://golf-charity-platform-production-5eca.up.railway.app/api"
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://golf-charity-platform-production-5eca.up.railway.app/api/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
